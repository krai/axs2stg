{
  "_parent_entries": [
    ["^", "byname", "python_script"],
    ["^", "byname", "base_loadgen_program"],
    ["^", "byname", "nvidia_gpu_support"]
  ],
  "_producer_rules": [
    [ ["loadgen_output", "task=text_to_image", "framework=stageai"], [["get", "pipeline"]] ],
    [ ["python_package", "package_name=thestage-elastic-models"], [["get_kernel"],["byname","pip"],["install"]], { "pip_options": "--extra-index-url https://thestage.jfrog.io/artifactory/api/pypi/pypi-thestage-ai-production/simple" } ]
  ],
  "abs_script_path": ["^^", "get_path", [["text_to_image", "main.py"]]],
  "this_entry_path": [ "^^", "get_path", "" ],
  "numpy_query": ["python_package", "package_name=numpy", "package_version=1.24.0"],
  "pandas_query": ["python_package", "package_name=pandas", "package_version=2.3.0"],
  "scipy_query": ["python_package", "package_name=scipy", "package_version=1.15.3"],
  "torch_query": ["python_package", "package_name=torch", "package_version=2.6.0"],
  "torchvision_query": ["python_package", "package_name=torchvision", "package_version=0.22.1"],
  "transformers_query": ["python_package", "package_name=transformers", "package_version=4.52.3"],
  "accelerate_query": ["python_package", "package_name=accelerate", "package_version=1.9.0"],
  "torchmetrics_query": ["python_package", "package_name=torchmetrics[image]", "package_version=1.2.0"],
  "open_clip_torch_query": ["python_package", "package_name=open-clip-torch", "package_version=2.7.0"],
  "opencv_python_query": ["python_package", "package_name=opencv-python", "package_version=4.8.1.78"],
  "pycocotools_query": ["python_package", "package_name=pycocotools", "package_version=2.0.7"],
  "loadgen_query": ["python_package", "package_name=mlcommons-loadgen", "package_version=5.1.0"],
  "elastic_models_query": ["python_package","package_name=thestage-elastic-models","package_version=0.1.1"],
  "tensorrt_query": ["python_package", "package_name=tensorrt", "package_version=10.13.0.35"],
  "tensorrt_cu12_query": ["python_package", "package_name=tensorrt-cu12", "package_version=10.13.0.35"],
  "tensorrt_cu12_bindings_query": ["python_package", "package_name=tensorrt_cu12_bindings", "package_version=10.13.0.35"],
  "tensorrt_cu12_libs_query": ["python_package", "package_name=tensorrt_cu12_libs", "package_version=10.13.0.35"],
  "python_deps": [
    ["^^", "python_sync_pip_package", [["^^", "get", "numpy_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "pandas_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "tensorrt_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "tensorrt_cu12_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "tensorrt_cu12_bindings_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "tensorrt_cu12_libs_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "scipy_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "transformers_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "torchvision_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "elastic_models_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "accelerate_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "torchmetrics_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "open_clip_torch_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "opencv_python_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "pycocotools_query"]]],
    ["^^", "python_sync_pip_package", [["^^", "get", "loadgen_query"]]]
  ],
  "desired_python_version": "3.10.12",
  "dataset_query": ["^^", "substitute", ["downloaded,dataset_name=#{dataset_name}#,num_images=#{num_images}#,num_workers=#{num_workers}#"]],
  "dataset_entry": ["^", "byquery", [["^^", "get", "dataset_query"]], {}, ["dataset_query"]],
  "dataset_path": ["^^", "execute", [[
      ["get", "dataset_entry"],
      ["get_path", ""]
    ]]
  ],
  "___dataset_path": ["^^", "get_path", [["text_to_image_using_loadgen", "text_to_image", "coco2014"]]],
  "__dataset_path": "/home/ubuntu/work_collection/axs2stg-dev/text_to_image_using_loadgen/text_to_image/coco2014",
  "num_workers": 1,
  "num_images": 5000,
  "profile_name": "stable-diffusion-xl-stageai",
  "dataset_name": "coco-1024",
  "backend": "stageai",
  "backend_cmd": ["^^", "substitute", "--backend #{backend}#"],
  "model_path": "stabilityai/stable-diffusion-xl-base-1.0",
  "model_name": "stable-diffusion-xl",
  "stageai_model_path": null,
  "stageai_model_path_cmd": ["^^", "case", [["^^", "get", "stageai_model_path"], null, ""], {"default_value":["^^","substitute","--stageai-model-path #{stageai_model_path}#"]}],
  "axs_device_id": null,
  "axs_device_id_cmd": ["^^","case",[["^^","get","axs_device_id"],null,""],{"default_value":["^^","substitute","--axs_device_id #{axs_device_id}#"]}],
  "latent_dir": ["^^","get_path",[["text_to_image","tools","latents.pt"]]],
  "input_data_types": "int32",
  "retraining": "No",
  "starting_weights_filename": "Hugginface model weights hosted by MLCommons",
  "weight_data_types": "int8",
  "weight_transformations": "quantization, affine fusion",
  "url": "https://huggingface.co/stabilityai/stable-diffusion-xl-base-1.0",
  "loadgen_dataset_size":5000,
  "loadgen_buffer_size":5000,
  "loadgen_compliance_test":false,
  "device":["^","case",[["^^","get","num_gpus"],"0","cpu"],{"default_value":"cuda"},["num_gpus"]],
  "dtype":"fp16",
  "max_batchsize":1,
  "samples_per_query":8,
  "latent_framework":"torch",
  "qps":null,
  "qps_cmd":["^^","case",[["^^","get","qps"],null,""],{"default_value":["^^","substitute","--qps #{qps}#"]}],
  "time":null,
  "time_cmd":["^^","case",[["^^","get","time"],null,""],{"default_value":["^^","substitute","--time #{time}#"]}],
  "performance_sample_count":null,
  "performance_sample_count_cmd":["^^","case",[["^^","get","performance_sample_count"],null,""],{"default_value":["^^","substitute","--performance-sample-count #{performance_sample_count}#"]}],
  "threads":1,
  "find_peak_performance":false,
  "find_peak_performance_cmd":["^^","case",[["^^","get","find_peak_performance"],false,""],{"default_value":["^^","substitute","--find-peak-performance #{find_peak_performance}#"]}],
  "count":null,
  "count_cmd":["^^","case",[["^^","get","count"],null,""],{"default_value":["^^","substitute","--count #{count}#"]}],
  "debug":null,
  "debug_cmd":["^^","case",[["^^","get","debug"],null,""],{"default_value":["^^","substitute","--debug #{debug}#"]}],
  "max_latency":null,
  "max_latency_cmd":["^^","case",[["^^","get","max_latency"],null,""],{"default_value":["^^","substitute","--max-latency #{max_latency}#"]}],
  "ids_path":["^^","get_path",[["text_to_image","tools","sample_ids.txt"]]],
  "accuracy":false,
  "accuracy_cmd": [ "^^", "case", [ [ "^^", "get", "loadgen_mode"],
        "AccuracyOnly", "--accuracy" ],
        { "default_value": "" }
  ],
  "_extra_env": {
    "TORCHINDUCTOR_CACHE_DIR": "/home/ubuntu/cache",
    "TRITON_CACHE_DIR": "/home/ubuntu/cache/triton"
  },
  "output_entry_parents":["AS^IS","AS^IS",["^","byname","base_text_to_image_loadgen_experiment"]],
  "output_entry_param_names":[
    "loadgen_compliance_test","num_workers","dataset_name","dataset_path","num_images","model_name","model_path","stageai_model_path","axs_device_id","input_data_types","retraining","weight_data_types","url","weight_transformations","profile_name","backend","device","dtype","max_batchsize","samples_per_query","latent_framework","time","performance_sample_count","threads","count","debug","max_latency","ids_path","accuracy","latent_dir"
  ],
  "script_extra_params":[
    "^^","substitute",
    "--dataset \"#{dataset_name}#\" --dataset-path #{dataset_path}# --profile #{profile_name}# --scenario #{loadgen_scenario}# --device #{device}# --max-batchsize #{max_batchsize}# --threads #{threads}# #{accuracy_cmd}# #{find_peak_performance_cmd}# #{backend_cmd}# --model-name #{model_name}# --model-path #{model_path}# #{stageai_model_path_cmd}# --dtype #{dtype}# #{qps_cmd}# --latent-framework #{latent_framework}# #{time_cmd}# #{count_cmd}# #{debug_cmd}# #{performance_sample_count_cmd}# #{max_latency_cmd}# --samples-per-query #{samples_per_query}# --ids-path #{ids_path}# --output #{output_dir}# #{axs_device_id_cmd}# --latent_dir #{latent_dir}# ; echo #{input_parameters_file_path}#"
  ]
}

